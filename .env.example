# Django
DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Database (PostgreSQL in production; SQLite used when USE_SQLITE=True)
USE_SQLITE=True
DATABASE_URL=postgres://crypto_user:crypto_pass@localhost:5432/crypto_invest

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Email (console backend in dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=CryptoInvest <noreply@cryptoinvest.local>
SITE_NAME=CryptoInvest
SITE_URL=http://127.0.0.1:8000

# Security
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_TIME=1

# Platform
MIN_WITHDRAWAL=10
MAX_WITHDRAWAL=100000
DEFAULT_CURRENCY=USD
REFERRAL_BONUS_PERCENT=5

# Social login (optional — leave empty to hide buttons)
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Authorized redirect URI: {SITE_URL}/accounts/oauth/google/callback/
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# X Developer Portal → Project → User authentication settings (OAuth 2.0)
# Callback URI: {SITE_URL}/accounts/oauth/x/callback/
X_OAUTH_CLIENT_ID=
X_OAUTH_CLIENT_SECRET=
