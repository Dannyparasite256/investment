# Copy to .env on PythonAnywhere and edit values.
# nano ~/investment/.env

DEBUG=False
SECRET_KEY=paste-a-long-random-secret-here
ALLOWED_HOSTS=investment256.pythonanywhere.com
CSRF_TRUSTED_ORIGINS=https://investment256.pythonanywhere.com

# Simple PA deploy (no Redis / Postgres required)
USE_SQLITE=True
USE_REDIS_CACHE=False
CELERY_TASK_ALWAYS_EAGER=True

SITE_NAME=CryptoInvest
SITE_URL=https://investment256.pythonanywhere.com

# Email: console = logs only; switch to SMTP when ready
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=CryptoInvest <noreply@yourdomain.com>

# PA already terminates SSL; avoid redirect loops on free plans
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

MIN_WITHDRAWAL=10
MAX_WITHDRAWAL=100000
DEFAULT_CURRENCY=USD
REFERRAL_BONUS_PERCENT=5
