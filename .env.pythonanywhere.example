# Copy to .env on PythonAnywhere and edit values.
# nano ~/investment/.env

DEBUG=False
SECRET_KEY=paste-a-long-random-secret-here
ALLOWED_HOSTS=investment256.pythonanywhere.com
CSRF_TRUSTED_ORIGINS=https://investment256.pythonanywhere.com

# Simple PA deploy (no Redis / Postgres required)
USE_SQLITE=True
USE_REDIS_CACHE=False
CELERY_TASK_ALWAYS_EAGER=True

SITE_NAME=CryptoInvest
SITE_URL=https://investment256.pythonanywhere.com

# ---------------------------------------------------------------------------
# EMAIL (required for login OTP, password reset, withdraw codes)
# console = prints to server log ONLY — inbox stays empty!
# ---------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
# Your Gmail address:
EMAIL_HOST_USER=yourgmail@gmail.com
# Google Account → Security → 2-Step Verification → App passwords → create one
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
DEFAULT_FROM_EMAIL=CryptoInvest <yourgmail@gmail.com>

# Free email OTP
EMAIL_OTP_LOGIN_REQUIRED=True
EMAIL_OTP_TTL_MINUTES=10

# PA already terminates SSL; avoid redirect loops on free plans
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

MIN_WITHDRAWAL=10
MAX_WITHDRAWAL=100000
DEFAULT_CURRENCY=USD
REFERRAL_BONUS_PERCENT=5

# Social login (optional)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
X_OAUTH_CLIENT_ID=
X_OAUTH_CLIENT_SECRET=
